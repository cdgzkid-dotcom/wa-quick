# ── Base de datos ───────────────────────────────────────────
MONGODB_URI="mongodb://localhost:27017/wa_quick"

# ── Web Push (npx web-push generate-vapid-keys) ─────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your_vapid_public_key_here"
VAPID_PRIVATE_KEY="your_vapid_private_key_here"
VAPID_SUBJECT="mailto:your@email.com"

# ── Cron (Vercel lo inyecta automáticamente en producción) ───
CRON_SECRET="your_random_secret_here"

# ── Google Contacts OAuth ────────────────────────────────────
# Consola: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_client_secret"
# El Client ID también debe estar disponible en el cliente para mostrar la sección
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your_client_id.apps.googleusercontent.com"
# URL pública de la app (para el redirect URI de OAuth)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
